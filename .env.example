# Django Secret Key — generate a unique one for production
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-real-secret-key

# Debug mode — set to False in production
DEBUG=True

# Database URL — uses dj-database-url format
# SQLite (default): sqlite:///db.sqlite3
# PostgreSQL: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=sqlite:///db.sqlite3

# Comma-separated list of allowed hostnames
# In production, set to your domain(s): example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF protection
# Must include scheme (https://) in production
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Default superuser credentials — used by the custom management command to
# create an initial admin account if one does not already exist
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme123
DEFAULT_ADMIN_EMAIL=admin@example.com